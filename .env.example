AWS_DEFAULT_REGION=us-east-1

# Local-only fallback credentials. Prefer runtime IAM roles in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_ASSUME_ROLE_ARN=
AWS_ASSUME_ROLE_SESSION_NAME=aws-dash-dashboard
AWS_ORG_ACCESS_ROLE_NAME=AwsDashReadOnlyRole
AWS_TAGGING_ROLE_NAME=AwsDashTagEditorRole

# Backend auth. Set AUTH_ENABLED=false only for local development without SSO.
AUTH_ENABLED=true
AUTH_TEST_MODE=false
AUTH_DEFAULT_TENANT=default
AUTH_ALLOW_DEFAULT_TENANT=false
OIDC_ISSUER=https://your-idp.example.com/oauth2/default
OIDC_AUDIENCE=api://aws-dash
OIDC_JWKS_URL=https://your-idp.example.com/oauth2/default/v1/keys
AUTH_GROUPS_CLAIM=groups
AUTH_ROLES_CLAIM=roles
AUTH_TENANT_CLAIM=aws_dash_tenant
AUTH_ACCOUNTS_CLAIM=aws_accounts
AUTH_VIEWER_GROUPS=aws-dash-viewers
AUTH_TAG_EDITOR_GROUPS=aws-dash-tag-editors
AUTH_ADMIN_GROUPS=aws-dash-admins
AUTH_TENANT_ACCOUNTS_JSON={"default":["123456789012"]}
CORS_ALLOW_ORIGINS=http://localhost:3000

# Frontend OIDC code flow.
APP_BASE_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:8000
AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters
AUTH_BYPASS_LOGIN=false
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=
OIDC_AUTHORIZATION_URL=https://your-idp.example.com/oauth2/default/v1/authorize
OIDC_TOKEN_URL=https://your-idp.example.com/oauth2/default/v1/token
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_SCOPES=openid profile email groups
